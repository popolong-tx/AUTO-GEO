# OCI GenAI Configuration
OCI_GENAI_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/20231130/actions/v1
OCI_GENAI_API_KEY=your-api-key-here
OCI_GENAI_MODEL=xai.grok-4.20-multi-agent-0309

# OCI Object Storage
OCI_OBJECT_STORAGE_NAMESPACE=your-namespace
OCI_OBJECT_STORAGE_BUCKET=byd-geo-reports
OCI_OBJECT_STORAGE_DATA_BUCKET=byd-geo-data

# OCI Authentication (for Object Storage access)
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=us-chicago-1

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
